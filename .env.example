NODE_ENV=development
APP_NAME=NestAdmin
APP_PORT=3000
APP_MODE=full

# Database
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=nestadmin

# Session & Auth
# SESSION_DRIVER: redis | database
# - redis    : simpan sesi di Redis (default). Sesi hilang saat Redis/container restart.
# - database : simpan sesi di tabel `sessions` DB utama. Persist lintas container restart.
#              Redis tetap dipakai untuk JWT blacklist.
SESSION_DRIVER=database
SESSION_SECRET=change-me-in-production-32chars-min
SESSION_TTL_HOURS=6
JWT_SECRET=change-me-in-production-32chars-min
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
DEFAULT_PAGE_SIZE=10

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Storage (local | oss | s3)
STORAGE_DRIVER=local
# Direktori file untuk driver local (relative ke project root); di-serve
# statis di /storage oleh main.ts. Default: public/storage
STORAGE_BASE_PATH=public/storage
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_SSL=true

# Mail
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=NestAdmin
MAIL_FROM_ADDRESS=

FE_CATALOG_TTL_HOURS=6
