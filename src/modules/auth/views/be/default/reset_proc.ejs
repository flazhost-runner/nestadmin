<meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

<div class="w-full max-w-5xl tw-card overflow-hidden grid md:grid-cols-2">
  <div class="hidden md:flex sidebar-gradient items-center justify-center p-10">
    <img src="<%= getFile('/modules/setting/login-image.png') %>" alt="Reset Password" class="max-w-full rounded-lg">
  </div>

  <div class="p-8 md:p-12 flex flex-col justify-center">
    <% if (typeof setting !== 'undefined' && setting && setting.logo) { %>
    <img src="<%= getFile(setting.logo) %>" alt="Logo" class="h-14 mx-auto object-contain mb-6">
    <% } %>

    <% if (typeof flash !== 'undefined' && flash && flash.success && flash.success.length) { %>
    <div class="alert alert-success mb-3"><%= flash.success[0] %></div>
    <% } %>

    <% if (typeof flash !== 'undefined' && flash && flash.error && flash.error.length) { %>
    <div class="alert alert-danger mb-3"><%= flash.error[0] %></div>
    <% } %>

    <h1 class="text-2xl font-bold mb-1" style="color:var(--primary)">Reset Password</h1>
    <p class="text-sm text-gray-500 mb-4">Enter Your New Password</p>

    <form method="POST" action="/admin/v1/auth/reset/process">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">

      <div class="mb-3">
        <input type="text" name="otp" maxlength="6" class="form-control text-center tracking-widest"
          placeholder="6-digit OTP" value="<%= getOld('otp') %>">
      </div>

      <div class="mb-3">
        <input type="password" name="password" class="form-control" placeholder="New Password">
      </div>

      <button type="submit" class="btn btn-primary-tw w-100 py-2 mb-3">Reset Password</button>

      <p class="text-center text-sm">
        <a href="/admin/v1/auth/reset/req" class="text-primary-tw text-decoration-none">back?</a>
      </p>
    </form>
  </div>
</div>
