<!-- Footer section -->
<footer class="bg-neutral-900 dark:bg-neutral-950 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <% if (typeof setting !== 'undefined' && setting && setting.logo) { %>
        <img src="/<%= setting.logo %>" alt="Logo" class="h-10 mb-4">
        <% } else { %>
        <h3 class="text-xl font-bold mb-4"><%= (typeof setting !== 'undefined' && setting && setting.name) ? setting.name : 'NestAdmin' %></h3>
        <% } %>
        <% if (typeof setting !== 'undefined' && setting && setting.description) { %>
        <p class="text-neutral-400 text-sm leading-relaxed max-w-sm"><%- setting.description %></p>
        <% } else { %>
        <p class="text-neutral-400 text-sm leading-relaxed max-w-sm">Partner with us to transform your vision into exceptional digital experiences.</p>
        <% } %>
      </div>
      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-neutral-300 mb-4">Contact</h4>
        <ul class="space-y-2 text-sm text-neutral-400">
          <% if (typeof setting !== 'undefined' && setting && setting.phone) { %>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <%= setting.phone %>
          </li>
          <% } %>
          <% if (typeof setting !== 'undefined' && setting && setting.email) { %>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <%= setting.email %>
          </li>
          <% } %>
          <% if (typeof setting !== 'undefined' && setting && setting.address) { %>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-orange-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <%= setting.address %>
          </li>
          <% } %>
        </ul>
      </div>
      <!-- Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wide text-neutral-300 mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="text-neutral-400 hover:text-orange-400 transition-colors">Home</a></li>
          <li><a href="#" class="text-neutral-400 hover:text-orange-400 transition-colors">About</a></li>
          <li><a href="#" class="text-neutral-400 hover:text-orange-400 transition-colors">Services</a></li>
          <li><a href="#" class="text-neutral-400 hover:text-orange-400 transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>
    <!-- Copyright -->
    <div class="pt-8 border-t border-neutral-800 text-center text-sm text-neutral-500">
      <% if (typeof setting !== 'undefined' && setting && setting.copyright) { %>
      <%- setting.copyright %>
      <% } else { %>
      &copy; <%= new Date().getFullYear() %> <%= (typeof setting !== 'undefined' && setting && setting.name) ? setting.name : 'NestAdmin' %>. All rights reserved.
      <% } %>
    </div>
  </div>
</footer>

<!-- Motion.js animations init -->
<script>
(function () {
  if (typeof window === 'undefined' || typeof Motion === 'undefined') return;
  const { animate, inView } = Motion;

  // Animate elements as they enter viewport
  document.querySelectorAll('[data-motion="hero"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], y: [30, 0] }, { duration: 0.6, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-motion="card"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], y: [20, 0] }, { duration: 0.5, easing: 'ease-out', delay: 0.1 });
    });
  });
  document.querySelectorAll('[data-motion="badge"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], scale: [0.9, 1] }, { duration: 0.4, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-motion="image"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], scale: [0.97, 1] }, { duration: 0.6, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-motion="button"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], y: [10, 0] }, { duration: 0.4, easing: 'ease-out', delay: 0.2 });
    });
  });
  document.querySelectorAll('[data-motion="logo"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1] }, { duration: 0.5, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-motion="avatar"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], scale: [0.8, 1] }, { duration: 0.3, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-motion="stats"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], y: [15, 0] }, { duration: 0.5, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-motion="social-proof"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1] }, { duration: 0.5, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-animate="heading"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], y: [20, 0] }, { duration: 0.6, easing: 'ease-out' });
    });
  });
  document.querySelectorAll('[data-animate="text"]').forEach(function(el) {
    inView(el, function() {
      animate(el, { opacity: [0, 1], y: [10, 0] }, { duration: 0.5, easing: 'ease-out', delay: 0.1 });
    });
  });
})();
</script>
